{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "airpoc/datasets/coco_instances.schema.json",
  "title": "AIRPOC dataset COCO instances file (layout-1)",
  "type": "object",
  "required": ["info", "images", "annotations", "categories"],
  "properties": {
    "info": {
      "type": "object",
      "required": ["spec_version", "split"],
      "properties": {
        "spec_version": { "const": "layout-1" },
        "split": { "enum": ["train", "val", "test"] },
        "description": { "type": "string" }
      }
    },
    "categories": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "name", "supercategory"],
        "properties": {
          "id": { "enum": [1, 2] },
          "name": { "enum": ["vehicle", "human"] },
          "supercategory": { "const": "object" }
        }
      }
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id", "file_name", "width", "height",
          "source_video_id", "timestamp_ms", "frame_index",
          "extraction_mode", "from_replay", "luma_conversion",
          "orig_resolution", "orig_pix_fmt", "orig_color_range",
          "frame_sha256", "split"
        ],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "file_name": { "type": "string", "pattern": "^[a-z0-9_-]+_[0-9]{8}_[bt]\\.png$" },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "source_video_id": { "type": "string", "pattern": "^[a-z0-9_-]+_[0-9a-f]{10}$" },
          "timestamp_ms": { "type": "integer", "minimum": 0 },
          "frame_index": { "type": "integer", "minimum": 0 },
          "extraction_mode": { "enum": ["baseline", "terminal"] },
          "from_replay": { "type": "boolean" },
          "terminal_source": { "enum": ["segments", "looming_heuristic", null] },
          "luma_conversion": { "enum": ["bt709_full", "bt601_full"] },
          "orig_resolution": {
            "type": "array", "minItems": 2, "maxItems": 2,
            "items": { "type": "integer", "minimum": 1 }
          },
          "orig_pix_fmt": { "type": "string" },
          "orig_color_range": { "enum": ["tv", "pc", "unknown"] },
          "exclusion_masks_applied": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["x", "y", "w", "h"],
              "properties": {
                "x": { "type": "number" }, "y": { "type": "number" },
                "w": { "type": "number" }, "h": { "type": "number" },
                "type": { "type": "string" }
              }
            }
          },
          "frame_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "split": { "enum": ["train", "val", "test"] }
        }
      }
    },
    "annotations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id", "image_id", "category_id", "bbox", "area", "iscrowd",
          "score", "label_source", "review_status", "raw_label",
          "bbox_max_side_px", "cross_check"
        ],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "image_id": { "type": "integer", "minimum": 1 },
          "category_id": { "enum": [1, 2] },
          "bbox": {
            "type": "array", "minItems": 4, "maxItems": 4,
            "items": { "type": "number", "minimum": 0 }
          },
          "area": { "type": "number", "minimum": 0 },
          "iscrowd": { "enum": [0, 1] },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "label_source": { "enum": ["grounding_dino", "rtmdet", "gdino+rtmdet", "human"] },
          "review_status": { "enum": ["auto_ok", "reviewed_ok", "reviewed_edited"] },
          "raw_label": { "type": "string" },
          "bbox_max_side_px": { "type": "number", "minimum": 0 },
          "cross_check": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "required": ["rtmdet_iou", "agree"],
                "properties": {
                  "rtmdet_iou": { "type": "number", "minimum": 0, "maximum": 1 },
                  "agree": { "type": "boolean" }
                }
              }
            ]
          }
        }
      }
    }
  }
}
