[Unit]
Description=Force Jetson fan to 100% always (override nvfancontrol cold shutoff)
After=multi-user.target nvfancontrol.service

[Service]
Type=simple
ExecStartPre=-/bin/systemctl stop nvfancontrol
ExecStart=/usr/local/bin/fan-max.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
