// SPDX-License-Identifier: GPL-2.0-only
// IMX296 mono GS on Jetson Orin Nano (p3768) CSI connector CAM1 / port C.

/dts-v1/;
/plugin/;

#define CAM0_RST	TEGRA234_MAIN_GPIO(H, 3)
#define CAM0_PWDN	TEGRA234_MAIN_GPIO(H, 6)
#define CAM1_PWDN	TEGRA234_MAIN_GPIO(AC, 0)
#define CAM_I2C_MUX	TEGRA234_AON_GPIO(CC, 3)

#include <dt-bindings/tegra234-p3767-0000-common.h>
#include <dt-bindings/clock/tegra234-clock.h>

/ {
	overlay-name = "Camera IMX296-C";
	jetson-header-name = "Jetson 24pin CSI Connector";
	compatible = JETSON_COMPATIBLE_P3768;

	fragment@0 {
		target-path = "/";
		__overlay__ {
			tegra-capture-vi {
				num-channels = <1>;
				ports {
					#address-cells = <1>;
					#size-cells = <0>;
					vi_port1: port@1 {
						reg = <0>;
						imx296_vi_in1: endpoint {
							port-index = <2>;
							bus-width = <1>;
							remote-endpoint = <&imx296_csi_out1>;
						};
					};
				};
			};
			tegra-camera-platform {
				compatible = "nvidia, tegra-camera-platform";
				num_csi_lanes = <1>;
				max_lane_speed = <1500000>;
				min_bits_per_pixel = <10>;
				vi_peak_byte_per_pixel = <2>;
				vi_bw_margin_pct = <25>;
				max_pixel_rate = <750000>;
				isp_peak_byte_per_pixel = <5>;
				isp_bw_margin_pct = <25>;
				modules {
					cam_module1: module1 {
						badge = "imx296_rear";
						position = "rear";
						orientation = "1";
						cam_module1_drivernode0: drivernode0 {
							pcl_id = "v4l2_sensor";
							sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/cam_i2cmux/i2c@1/imx296_c@1a";
						};
					};
				};
			};
			bus@0 {
				host1x@13e00000 {
					nvcsi@15a00000 {
						num-channels = <1>;
						#address-cells = <1>;
						#size-cells = <0>;
						csi_chan1: channel@1 {
							reg = <0>;
							ports {
								#address-cells = <1>;
								#size-cells = <0>;
								csi_chan1_port0: port@0 {
									reg = <0>;
									imx296_csi_in1: endpoint@2 {
										port-index = <2>;
										bus-width = <1>;
										remote-endpoint = <&imx296_out1>;
									};
								};
								csi_chan1_port1: port@1 {
									reg = <1>;
									imx296_csi_out1: endpoint@3 {
										remote-endpoint = <&imx296_vi_in1>;
									};
								};
							};
						};
					};
				};
				cam_i2cmux {
					status = "okay";
					compatible = "i2c-mux-gpio";
					#address-cells = <1>;
					#size-cells = <0>;
					mux-gpios = <&gpio_aon CAM_I2C_MUX GPIO_ACTIVE_HIGH>;
					i2c-parent = <&cam_i2c>;
					i2c@1 {
						status = "okay";
						reg = <1>;
						#address-cells = <1>;
						#size-cells = <0>;
						imx296_c@1a {
							reset-gpios = <&gpio CAM1_PWDN GPIO_ACTIVE_HIGH>;
							clocks = <&bpmp TEGRA234_CLK_EXTPERIPH1>,
								 <&bpmp TEGRA234_CLK_EXTPERIPH1>;
							clock-names = "extperiph1", "pllp_grtba";
							mclk = "extperiph1";
							compatible = "sony,imx296";
							reg = <0x1a>;
							devnode = "video0";
							physical_w = "6.3";
							physical_h = "4.9";
							sensor_model = "imx296";
							use_sensor_mode_id = "true";
							mode0 { /* 1456x1088 60fps RAW10 mono */
								mclk_khz = "54000";	/* Waveshare IMX296 self-clocks at 54 MHz */
								num_lanes = "1";
								tegra_sinterface = "serial_c";
								phy_mode = "DPHY";
								discontinuous_clk = "no";	/* IMX296 uses continuous clock (per INNO-MAKER known-good) */
								lane_polarity = "0";	/* IMX296 1-lane: no swizzle (per INNO-MAKER known-good) */
								dpcm_enable = "false";
								cil_settletime = "0";
								active_w = "1456";
								active_h = "1088";
								mode_type = "bayer";
								pixel_phase = "rggb";
								pixel_t = "mono_y10";	/* mono Y10, not Bayer RG10 */
								csi_pixel_bit_depth = "10";
								readout_orientation = "0";
								line_length = "1100";
								inherent_gain = "1";
								mclk_multiplier = "22";
								pix_clk_hz = "118800000";
								gain_factor = "10";
								min_gain_val = "0";
								max_gain_val = "480";
								step_gain_val = "1";
								default_gain = "0";
								min_hdr_ratio = "1";
								max_hdr_ratio = "1";
								framerate_factor = "1000000";
								min_framerate = "2000000";
								max_framerate = "60000000";
								step_framerate = "1";
								default_framerate = "60000000";
								exposure_factor = "1000000";
								min_exp_time = "29";
								max_exp_time = "16000";
								step_exp_time = "1";
								default_exp_time = "10000";
								embedded_metadata_height = "2";	/* IMX296 emits 2 embedded data lines */
							};
							ports {
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									reg = <0>;
									imx296_out1: endpoint {
										status = "okay";
										port-index = <2>;
										bus-width = <1>;
										remote-endpoint = <&imx296_csi_in1>;
									};
								};
							};
						};
					};
				};
				gpio@6000d000 {
					camera-control-output-low {
						gpio-hog;
						output-low;
						gpios = <CAM1_PWDN 0>;
						label = "cam1-pwdn";
					};
				};
			};
		};
	};
};
